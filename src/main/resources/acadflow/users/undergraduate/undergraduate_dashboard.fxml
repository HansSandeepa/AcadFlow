<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="acadflow.contollers.users.undergraduate.UndergraduateDashboardController">

    <top>
        <VBox>
            <HBox spacing="20" style="-fx-background-color: #000060; -fx-padding: 15;">
                <children>
                    <VBox prefHeight="96.0">
                        <children>
                            <Label prefHeight="40.0" text="Acadflow - Undergraduate Potral" textFill="WHITE">
                                <font>
                                    <Font name="System Bold" size="28.0" />
                                </font>
                            </Label>
                            <HBox prefHeight="26.0">
                                <children>
                                    <Label fx:id="adminNameLabel" style="-fx-font-size: 14px;" text="Welcome " textFill="#ecf0f1">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                    <Label fx:id="username" text="Jhon Doe" textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                </children>
                                <VBox.margin>
                                    <Insets top="10.0" />
                                </VBox.margin>
                            </HBox>
                            <HBox prefHeight="100.0">
                                <children>
                                    <Label text="Registration Number: " textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                        <HBox.margin>
                                            <Insets />
                                        </HBox.margin>
                                    </Label>
                                    <Label fx:id="userRegNo" prefHeight="20.0" text="tg1234" textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                </children>
                                <VBox.margin>
                                    <Insets top="5.0" />
                                </VBox.margin>
                            </HBox>
                        </children>
                    </VBox>
                    <Region prefHeight="96.0" HBox.hgrow="ALWAYS" />
                    <VBox prefHeight="88.0" prefWidth="100.0">
                        <children>
                            <ImageView fx:id="userImg" fitHeight="76.0" fitWidth="98.0" pickOnBounds="true" preserveRatio="true" />
                            <Label alignment="CENTER" prefHeight="18.0" prefWidth="125.0" text="Undergraduate" textAlignment="CENTER" textFill="WHITE">
                                <font>
                                    <Font size="14.0" />
                                </font>
                            </Label>
                        </children>
                    </VBox>
                    <VBox prefHeight="96.0" prefWidth="70.0">
                        <children>
                            <Region prefHeight="33.0" prefWidth="100.0" visible="false" />
                            <Button fx:id="logoutBtn" onAction="#onLogoutBtnClick" prefHeight="34.0" prefWidth="68.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Logout">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                                <VBox.margin>
                                    <Insets />
                                </VBox.margin>
                            </Button>
                        </children>
                    </VBox>
                </children>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane BorderPane.alignment="CENTER">
            <content>

                <TabPane tabClosingPolicy="UNAVAILABLE">
                    <Tab text="My Profile">
                        <HBox prefHeight="795.0" prefWidth="993.0" spacing="30" style="-fx-padding: 20;">
                            <!-- Profile Picture Section -->
                            <VBox spacing="15" style="-fx-alignment: center; -fx-pref-width: 250;">
                                <ImageView fx:id="userMainImage" fitHeight="150" fitWidth="150" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" />
                                <Button fx:id="updateProPicBtn" onAction="#handleUploadButton" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Change Profile Picture" />
                            </VBox>

                            <!-- Profile Details -->
                            <VBox fx:id="formGrid" prefHeight="755.0" prefWidth="490.0" spacing="15" style="-fx-pref-width: 400;">
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Personal Information" />

                                <GridPane hgap="15" prefHeight="224.0" prefWidth="451.0" vgap="10">
                                    <Label style="-fx-font-weight: bold;" text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <Label fx:id="fullName" text="John Michael Doe" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label style="-fx-font-weight: bold;" text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <Label fx:id="regNoLabel" text="DEPT0000" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label style="-fx-font-weight: bold;" text="Email:" GridPane.rowIndex="5" />
                                    <TextField fx:id="emailField" editable="true" prefHeight="26.0" prefWidth="278.0" promptText="john.doe@students.ruhuna.ac.lk" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                    <Label style="-fx-font-weight: bold;" text="Address:" GridPane.rowIndex="7" />
                                    <TextArea fx:id="addressField" promptText="No. 123, Main Street, Galle" style="-fx-pref-height: 60;" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                    <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="8">
                                        <Button fx:id="updateBtn" onAction="#saveProfileDetails" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="Update Profile" />
                                        <Button fx:id="selfDetailsCancelBtn" onAction="#cancelSelfFormDetails" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Cancel" />
                                    </HBox>
                                    <Label layoutX="10.0" layoutY="38.0" style="-fx-font-weight: bold;" text="Department:" GridPane.rowIndex="2" />
                                    <Label fx:id="departmentNo" layoutX="99.0" layoutY="38.0" text="Dept." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <Label layoutX="10.0" layoutY="66.0" style="-fx-font-weight: bold;" text="Batch:" GridPane.rowIndex="3" />
                                    <Label fx:id="batchNo" layoutX="99.0" layoutY="66.0" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    <Label layoutX="10.0" layoutY="91.0" style="-fx-font-weight: bold;" text="Gender" GridPane.rowIndex="4" />
                                    <Label fx:id="genderField" layoutX="99.0" layoutY="10.0" text="gender" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                    <columnConstraints>
                                        <ColumnConstraints maxWidth="203.39999618530274" minWidth="19.4" prefWidth="73.59999389648438" />
                                        <ColumnConstraints maxWidth="365.4" minWidth="181.40000381469727" prefWidth="303.20000610351565" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                    </rowConstraints>
                                </GridPane>
                            </VBox>
                        </HBox>
                    </Tab>

                    <Tab text="My Courses &amp; Grades">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Academic Performance" />

                            <!-- GPA Card -->
                            <HBox spacing="20">
                                <VBox spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Current GPA" />
                                    <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="3.75" />
                                    <Label text="Overall GPA: 3.65" />
                                </VBox>

                                <VBox spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Credits Completed" />
                                    <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="45" />
                                    <Label text="Total Credits: 90" />
                                </VBox>
                            </HBox>

                            <!-- Courses Table -->
                            <TableView style="-fx-pref-height: 350;">
                                <columns>
                                    <TableColumn prefWidth="100" text="Course Code" />
                                    <TableColumn prefWidth="200" text="Course Name" />
                                    <TableColumn prefWidth="80" text="Credits" />
                                    <TableColumn prefWidth="100" text="CA Marks" />
                                    <TableColumn prefWidth="100" text="Exam Marks" />
                                    <TableColumn prefWidth="80" text="Total" />
                                    <TableColumn prefWidth="80" text="Grade" />
                                    <TableColumn prefWidth="100" text="Status" />
                                </columns>
                            </TableView>

                            <!-- Eligibility Status -->
                            <TitledPane text="Exam Eligibility">
                                <VBox spacing="10" style="-fx-padding: 15;">
                                    <Label text="CA Marks Requirement: ≥40% to sit for final exam" />
                                    <Label style="-fx-text-fill: #27ae60;" text="OOP (ICT2132): CA = 78% - Eligible ✓" />
                                    <Label style="-fx-text-fill: #27ae60;" text="Database (ICT2133): CA = 85% - Eligible ✓" />
                                    <Label style="-fx-text-fill: #27ae60;" text="Web Dev (ICT2134): CA = 92% - Eligible ✓" />
                                    <ProgressBar progress="0.85" style="-fx-pref-width: 300;" />
                                </VBox>
                            </TitledPane>
                        </VBox>
                    </Tab>

                    <Tab text="Attendance">
                        <VBox spacing="14" style="-fx-padding: 20;">

                            <!-- ── Title ── -->
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="My Attendance" />

                            <!-- ── Filter Bar ── -->
                            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #ecf0f1; -fx-padding: 12; -fx-background-radius: 6;">
                                <Label style="-fx-font-weight: bold;" text="Course:" />
                                <ComboBox fx:id="attCourseCombo" prefWidth="220" promptText="All Courses" />
                                <Label style="-fx-font-weight: bold;" text="Session Type:" />
                                <ComboBox fx:id="attSessionTypeCombo" prefWidth="120" />
                                <Button fx:id="attViewBtn" onAction="#loadAttendance" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" text="View" />
                            </HBox>

                            <!-- ── Summary Cards ── -->
                            <HBox spacing="16">
                                <!-- Theory card -->
                                <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-min-width: 200;">
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Theory Sessions" />
                                    <Label fx:id="attTheoryPresentLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0 / 0" />
                                    <Label fx:id="attTheoryTotalLabel" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="0 sessions" />
                                    <ProgressBar fx:id="attTheoryProgress" prefWidth="180" progress="0" />
                                    <Label fx:id="attTheoryPctLabel" style="-fx-font-size: 12px; -fx-text-fill: #555;" text="0.0%" />
                                </VBox>

                                <!-- Practical card -->
                                <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-min-width: 200;">
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Practical Sessions" />
                                    <Label fx:id="attPracticalPresentLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0 / 0" />
                                    <Label fx:id="attPracticalTotalLabel" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="0 sessions" />
                                    <ProgressBar fx:id="attPracticalProgress" prefWidth="180" progress="0" />
                                    <Label fx:id="attPracticalPctLabel" style="-fx-font-size: 12px; -fx-text-fill: #555;" text="0.0%" />
                                </VBox>

                                <!-- Combined card -->
                                <VBox spacing="6" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-min-width: 200;">
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Combined" />
                                    <Label fx:id="attCombinedPresentLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0 / 0" />
                                    <Label fx:id="attCombinedTotalLabel" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="0 sessions" />
                                    <ProgressBar fx:id="attCombinedProgress" prefWidth="180" progress="0" />
                                    <Label fx:id="attCombinedPctLabel" style="-fx-font-size: 12px; -fx-text-fill: #555;" text="0.0%" />
                                </VBox>

                                <!-- Eligibility badge -->
                                <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-min-width: 160;">
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Eligibility" />
                                    <Label fx:id="attEligibilityLabel" style="-fx-font-size: 13px; -fx-font-weight: bold;" text="—" />
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #95a5a6;" text="Requires ≥80% attendance" />
                                </VBox>
                            </HBox>

                            <!-- ── Detail Table ── -->
                            <TableView fx:id="attTableView" style="-fx-pref-height: 320;" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="attColCourse" prefWidth="180" text="Course" />
                                    <TableColumn fx:id="attColDate" prefWidth="100" text="Date" />
                                    <TableColumn fx:id="attColSession" prefWidth="100" text="Session" />
                                    <TableColumn fx:id="attColType" prefWidth="90" text="Type" />
                                    <TableColumn fx:id="attColStatus" prefWidth="80" text="Status" />
                                    <TableColumn fx:id="attColMedical" prefWidth="110" text="Medical Filed" />
                                    <TableColumn fx:id="attColApproval" prefWidth="110" text="Approval" />
                                </columns>
                                <placeholder>
                                    <Label style="-fx-text-fill: #95a5a6;" text="No attendance records found." />
                                </placeholder>
                            </TableView>

                        </VBox>
                    </Tab>

                    <Tab text="Medical">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Medical Records" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="refreshMedicalBtn" onAction="#refreshMedicalRecords"
                                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;"
                                        text="Refresh" />
                            </HBox>

                            <TableView fx:id="medicalTableView" style="-fx-pref-height: 300;">
                                <columns>
                                    <TableColumn fx:id="medDateCol" prefWidth="120" text="Date" />
                                    <TableColumn fx:id="medSessionCol" prefWidth="100" text="Session Type" />
                                    <TableColumn fx:id="medCourseCol" prefWidth="150" text="Course" />
                                    <TableColumn fx:id="medStatusCol" prefWidth="100" text="Status" />
                                </columns>
                            </TableView>

                            <Button fx:id="SubmitMedicalBtn" onAction="#handleSubmitMedical" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 200;" text="Submit New Medical" />
                        </VBox>
                    </Tab>

                    <Tab text="Timetable">
                        <VBox spacing="10" style="-fx-padding: 20;">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Weekly Timetable" />

                            <ComboBox promptText="Select Week" style="-fx-pref-width: 150;" />

                            <TableView style="-fx-pref-height: 450;">
                                <columns>
                                    <TableColumn prefWidth="100" text="Time" />
                                    <TableColumn prefWidth="150" text="Monday" />
                                    <TableColumn prefWidth="150" text="Tuesday" />
                                    <TableColumn prefWidth="150" text="Wednesday" />
                                    <TableColumn prefWidth="150" text="Thursday" />
                                    <TableColumn prefWidth="150" text="Friday" />
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>

                    <!--- NOTICE BAR -->
                    <Tab text="Notices">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="University Notices">
                                <font>
                                    <Font name="Arial Bold" size="18" />
                                </font>
                            </Label>

                            <!-- Search and Filter Bar -->
                            <HBox spacing="15">
                                <TextField fx:id="searchNoticeField" prefWidth="250" promptText="Search by title..." />
                                <Button fx:id="searchNoticeButton" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="Search" />

                                <Region HBox.hgrow="ALWAYS" />

                                <Label text="Filter by Audience:" />
                                <ComboBox fx:id="filterAudienceCombo" prefWidth="120" />

                                <CheckBox fx:id="showImportantOnlyCheck" text="Show Important Only" />
                            </HBox>

                            <!-- Statistics Bar -->
                            <HBox spacing="20">
                                <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="Total Notices" />
                                    <Label fx:id="totalNoticesLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                                </VBox>

                                <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="Important Notices" />
                                    <Label fx:id="importantNoticesLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="0" />
                                </VBox>
                            </HBox>

                            <!-- Notices Table and Details Split View -->
                            <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
                                <TableView fx:id="noticesTableView" prefHeight="400">
                                    <columns>
                                        <TableColumn prefWidth="60" text="ID" />
                                        <TableColumn prefWidth="250" text="Title" />
                                        <TableColumn prefWidth="100" text="Date" />
                                        <TableColumn prefWidth="100" text="Audience" />
                                        <TableColumn prefWidth="80" text="Important" />
                                    </columns>
                                </TableView>

                                <VBox spacing="10" style="-fx-padding: 10;">
                                    <Label fx:id="noticeTitleLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Select a notice to view details" />
                                    <Separator />
                                    <TextArea fx:id="noticeDetailArea" editable="false" prefHeight="350" style="-fx-font-size: 14px;" wrapText="true" />
                                </VBox>
                            </SplitPane>

                            <!-- Note for Lecturer -->
                            <HBox alignment="CENTER_RIGHT">
                                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="📢 Notices are published by Admin. Contact Admin for any corrections." />
                            </HBox>
                        </VBox>
                    </Tab>
                </TabPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
