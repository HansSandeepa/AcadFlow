<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.CheckBox?>
<BorderPane style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="acadflow.contollers.users.undergraduate.UndergraduateDashboardController">

    <top>
        <VBox>
            <HBox spacing="20" style="-fx-background-color: #000060; -fx-padding: 15;">
                <children>
                    <VBox prefHeight="96.0">
                        <children>
                            <Label prefHeight="40.0" text="Acadflow - Undergraduate Potral" textFill="WHITE">
                                <font>
                                    <Font name="System Bold" size="28.0" />
                                </font>
                            </Label>
                            <HBox prefHeight="26.0">
                                <children>
                                    <Label fx:id="adminNameLabel" style="-fx-font-size: 14px;" text="Welcome " textFill="#ecf0f1">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                    <Label fx:id="username" text="Jhon Doe" textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                </children>
                                <VBox.margin>
                                    <Insets top="10.0" />
                                </VBox.margin>
                            </HBox>
                            <HBox prefHeight="100.0">
                                <children>
                                    <Label text="Registration Number: " textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                        <HBox.margin>
                                            <Insets />
                                        </HBox.margin>
                                    </Label>
                                    <Label fx:id="userRegNo" prefHeight="20.0" text="tg1234" textFill="WHITE">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Label>
                                </children>
                                <VBox.margin>
                                    <Insets top="5.0" />
                                </VBox.margin>
                            </HBox>
                        </children>
                    </VBox>
                    <Region prefHeight="96.0" HBox.hgrow="ALWAYS" />
                    <VBox prefHeight="88.0" prefWidth="100.0">
                        <children>
                            <ImageView fx:id="userImg" fitHeight="76.0" fitWidth="98.0" pickOnBounds="true" preserveRatio="true" />
                            <Label alignment="CENTER" prefHeight="18.0" prefWidth="125.0" text="Undergraduate" textAlignment="CENTER" textFill="WHITE">
                                <font>
                                    <Font size="14.0" />
                                </font>
                            </Label>
                        </children>
                    </VBox>
                    <VBox prefHeight="96.0" prefWidth="70.0">
                        <children>
                            <Region prefHeight="33.0" prefWidth="100.0" visible="false" />
                            <Button fx:id="logoutBtn" onAction="#onLogoutBtnClick" prefHeight="34.0" prefWidth="68.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Logout">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                                <VBox.margin>
                                    <Insets />
                                </VBox.margin>
                            </Button>
                        </children>
                    </VBox>
                </children>
            </HBox>
        </VBox>
    </top>
   <center>
      <ScrollPane BorderPane.alignment="CENTER">
         <content>

                     <TabPane tabClosingPolicy="UNAVAILABLE">
                   <Tab text="My Profile">
                       <HBox prefHeight="795.0" prefWidth="993.0" spacing="30" style="-fx-padding: 20;">
                           <!-- Profile Picture Section -->
                           <VBox spacing="15" style="-fx-alignment: center; -fx-pref-width: 250;">
                               <ImageView fx:id="userMainImage" fitHeight="150" fitWidth="150" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" />
                               <Button fx:id="updateProPicBtn" onAction="#handleUploadButton" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Change Profile Picture" />
                           </VBox>

                                 <!-- Profile Details -->
                           <VBox fx:id="formGrid" prefHeight="755.0" prefWidth="490.0" spacing="15" style="-fx-pref-width: 400;">
                               <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Personal Information" />

                                     <GridPane hgap="15" prefHeight="224.0" prefWidth="451.0" vgap="10">
                                   <Label style="-fx-font-weight: bold;" text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                   <Label fx:id="fullName" text="John Michael Doe" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                         <Label style="-fx-font-weight: bold;" text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                   <Label fx:id="regNoLabel" text="DEPT0000" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                         <Label style="-fx-font-weight: bold;" text="Email:" GridPane.rowIndex="5" />
                                   <TextField fx:id="emailField" editable="true" prefHeight="26.0" prefWidth="278.0" promptText="john.doe@students.ruhuna.ac.lk" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                         <Label style="-fx-font-weight: bold;" text="Address:" GridPane.rowIndex="7" />
                                   <TextArea fx:id="addressField" promptText="No. 123, Main Street, Galle" style="-fx-pref-height: 60;" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                         <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="8">
                                       <Button fx:id="updateBtn" onAction="#saveProfileDetails" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="Update Profile" />
                                       <Button fx:id="selfDetailsCancelBtn" onAction="#cancelSelfFormDetails" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Cancel" />
                                   </HBox>
                           <Label layoutX="10.0" layoutY="38.0" style="-fx-font-weight: bold;" text="Department:" GridPane.rowIndex="2" />
                           <Label fx:id="departmentNo" layoutX="99.0" layoutY="38.0" text="Dept." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                           <Label layoutX="10.0" layoutY="66.0" style="-fx-font-weight: bold;" text="Batch:" GridPane.rowIndex="3" />
                           <Label fx:id="batchNo" layoutX="99.0" layoutY="66.0" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                           <Label layoutX="10.0" layoutY="91.0" style="-fx-font-weight: bold;" text="Gender" GridPane.rowIndex="4" />
                           <Label fx:id="genderField" layoutX="99.0" layoutY="10.0" text="gender" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                   <columnConstraints>
                                       <ColumnConstraints maxWidth="203.39999618530274" minWidth="19.4" prefWidth="73.59999389648438" />
                                       <ColumnConstraints maxWidth="365.4" minWidth="181.40000381469727" prefWidth="303.20000610351565" />
                                   </columnConstraints>
                                   <rowConstraints>
                                       <RowConstraints />
                                       <RowConstraints />
                              <RowConstraints />
                                       <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                       <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                       <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                                   </rowConstraints>
                               </GridPane>
                           </VBox>
                       </HBox>
                   </Tab>

                         <!-- ═══════════════════════════════════════════════════════
                              MY COURSES & GRADES TAB  (undergraduate — read only)
                              All data is loaded from exam_marks table via ExamMarkDAO.
                              fx:id fields are bound in UndergraduateDashboardController.
                              ═══════════════════════════════════════════════════════ -->
                         <Tab text="My Courses &amp; Grades">
                           <VBox spacing="15" style="-fx-padding: 20;">
                               <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Academic Performance" />

                               <!-- GPA summary cards — values set by controller -->
                               <HBox spacing="20">
                                   <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10; -fx-min-width: 160;">
                                       <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" text="Overall GPA" />
                                       <!-- fx:id="gpaLabel" — updated by loadGradesForStudent() -->
                                       <Label fx:id="gpaLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="—" />
                                       <Label style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="Weighted GPA (4.0 scale)" />
                                   </VBox>
                                   <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10; -fx-min-width: 160;">
                                       <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" text="Total Marks Records" />
                                       <!-- fx:id="totalMarksLabel" — updated by loadGradesForStudent() -->
                                       <Label fx:id="totalMarksLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                                       <Label style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="Across all courses" />
                                   </VBox>
                               </HBox>

                               <!-- Marks table — columns bound in controller via PropertyValueFactory -->
                               <!-- fx:id="marksTableView" -->
                               <TableView fx:id="marksTableView" style="-fx-pref-height: 320;">
                                   <columns>
                                       <!-- Course Code — bound to courseId property -->
                                       <TableColumn fx:id="gradesCourseCodeCol" prefWidth="110" text="Course Code" />
                                       <!-- Course Name — bound to courseName property (joined) -->
                                       <TableColumn fx:id="gradesCourseNameCol" prefWidth="200" text="Course Name" />
                                       <!-- Credits — bound to credits property (joined) -->
                                       <TableColumn fx:id="gradesCreditsCol" prefWidth="65" text="Credits" />
                                       <!-- Assessment type: T=Theory CA, P=Practical CA -->
                                       <TableColumn fx:id="gradesAssessmentCol" prefWidth="110" text="Assessment" />
                                       <!-- Session type: T=Theory, P=Practical -->
                                       <TableColumn fx:id="gradesSessionCol" prefWidth="90" text="Session" />
                                       <!-- Numeric mark (0-100) -->
                                       <TableColumn fx:id="gradesMarkCol" prefWidth="70" text="Mark" />
                                       <!-- Letter grade auto-calculated from mark -->
                                       <TableColumn fx:id="gradesGradeCol" prefWidth="65" text="Grade" />
                                   </columns>
                               </TableView>

                               <!-- Eligibility section — populated dynamically by controller -->
                               <!-- fx:id="eligibilityBox" — VBox children added at runtime -->
                               <TitledPane expanded="true" text="Exam Eligibility  (CA ≥ 40 required)">
                                   <VBox fx:id="eligibilityBox" spacing="8" style="-fx-padding: 12;">
                                       <!-- Rows added programmatically by buildEligibilityRows() -->
                                       <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"
                                              text="Loading eligibility data..." />
                                   </VBox>
                               </TitledPane>
                           </VBox>
                         </Tab>

                         <Tab text="Attendance">
                       <VBox spacing="15" style="-fx-padding: 20;">
                           <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Attendance Records" />

                                 <HBox spacing="15">
                               <ComboBox promptText="Select Course" style="-fx-pref-width: 200;">
                                   <items>
                                       <FXCollections fx:factory="observableArrayList">
                                           <String fx:value="OOP - ICT2132" />
                                           <String fx:value="Database - ICT2133" />
                                           <String fx:value="Web Development - ICT2134" />
                                       </FXCollections>
                                   </items>
                               </ComboBox>
                               <Button style="-fx-background-color: #3498db; -fx-text-fill: white;" text="View Attendance" />
                           </HBox>

                                 <HBox spacing="20">
                               <!-- Theory Attendance -->
                               <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                                   <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Theory Sessions" />
                                   <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="12 / 15" />
                                   <Label text="80% Attendance" />
                                   <ProgressBar progress="0.80" style="-fx-pref-width: 200;" />
                               </VBox>

                                     <!-- Practical Attendance -->
                               <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                                   <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Practical Sessions" />
                                   <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" text="10 / 15" />
                                   <Label text="66.7% Attendance" />
                                   <ProgressBar progress="0.667" style="-fx-pref-width: 200;" />
                               </VBox>

                                     <!-- Combined -->
                               <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                                   <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Combined" />
                                   <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="22 / 30" />
                                   <Label text="73.3% Attendance" />
                                   <ProgressBar progress="0.733" style="-fx-pref-width: 200;" />
                               </VBox>
                           </HBox>

                                 <!-- Attendance Calendar/Table -->
                           <TableView style="-fx-pref-height: 200;">
                               <columns>
                                   <TableColumn prefWidth="120" text="Date" />
                                   <TableColumn prefWidth="120" text="Session Type" />
                                   <TableColumn prefWidth="100" text="Status" />
                                   <TableColumn prefWidth="120" text="Medical Submitted" />
                               </columns>
                           </TableView>
                       </VBox>
                   </Tab>

                         <Tab text="Medical">
                       <VBox spacing="15" style="-fx-padding: 20;">
                           <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Medical Records" />

                                 <TableView style="-fx-pref-height: 300;">
                               <columns>
                                   <TableColumn prefWidth="120" text="Date" />
                                   <TableColumn prefWidth="150" text="Session" />
                                   <TableColumn prefWidth="200" text="Reason" />
                                   <TableColumn prefWidth="100" text="Status" />
                               </columns>
                           </TableView>

                                 <Button style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 200;" text="Submit New Medical" />
                       </VBox>
                   </Tab>

                         <Tab text="Timetable">
                       <VBox spacing="10" style="-fx-padding: 20;">
                           <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Weekly Timetable" />

                                 <ComboBox promptText="Select Week" style="-fx-pref-width: 150;" />

                                 <TableView style="-fx-pref-height: 450;">
                               <columns>
                                   <TableColumn prefWidth="100" text="Time" />
                                   <TableColumn prefWidth="150" text="Monday" />
                                   <TableColumn prefWidth="150" text="Tuesday" />
                                   <TableColumn prefWidth="150" text="Wednesday" />
                                   <TableColumn prefWidth="150" text="Thursday" />
                                   <TableColumn prefWidth="150" text="Friday" />
                               </columns>
                           </TableView>
                       </VBox>
                   </Tab>

                         <!--- NOTICE BAR -->
                         <Tab text="Notices">
                             <VBox spacing="15" style="-fx-padding: 20;">
                                 <Label text="University Notices">
                                     <font>
                                         <Font name="Arial Bold" size="18" />
                                     </font>
                                 </Label>

                                 <!-- Search and Filter Bar -->
                                 <HBox spacing="15">
                                     <TextField fx:id="searchNoticeField" prefWidth="250" promptText="Search by title..." />
                                     <Button fx:id="searchNoticeButton" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="Search" />

                                     <Region HBox.hgrow="ALWAYS" />

                                     <Label text="Filter by Audience:" />
                                     <ComboBox fx:id="filterAudienceCombo" prefWidth="120" />

                                     <CheckBox fx:id="showImportantOnlyCheck" text="Show Important Only" />
                                 </HBox>

                                 <!-- Statistics Bar -->
                                 <HBox spacing="20">
                                     <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
                                         <Label text="Total Notices" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                         <Label fx:id="totalNoticesLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                                     </VBox>

                                     <VBox spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
                                         <Label text="Important Notices" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                         <Label fx:id="importantNoticesLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                                     </VBox>
                                 </HBox>

                                 <!-- Notices Table and Details Split View -->
                                 <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
                                     <TableView fx:id="noticesTableView" prefHeight="400">
                                         <columns>
                                             <TableColumn prefWidth="60" text="ID" />
                                             <TableColumn prefWidth="250" text="Title" />
                                             <TableColumn prefWidth="100" text="Date" />
                                             <TableColumn prefWidth="100" text="Audience" />
                                             <TableColumn prefWidth="80" text="Important" />
                                         </columns>
                                     </TableView>

                                     <VBox spacing="10" style="-fx-padding: 10;">
                                         <Label fx:id="noticeTitleLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Select a notice to view details" />
                                         <Separator />
                                         <TextArea fx:id="noticeDetailArea" editable="false" wrapText="true" style="-fx-font-size: 14px;" prefHeight="350" />
                                     </VBox>
                                 </SplitPane>

                                 <!-- Note for Lecturer -->
                                 <HBox alignment="CENTER_RIGHT">
                                     <Label text="📢 Notices are published by Admin. Contact Admin for any corrections." style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                 </HBox>
                             </VBox>
                         </Tab>
               </TabPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
