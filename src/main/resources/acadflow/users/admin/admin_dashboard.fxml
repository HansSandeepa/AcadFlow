                  <Button fx:id="coursesBtn" alignment="CENTER" mnemonicParsing="false" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: #000060; -fx-cursor: hand;" text="  Manage Courses" textFill="WHITE">
                     <font><Font name="System Bold" size="15.0" /></font>
