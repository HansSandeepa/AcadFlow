<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="acadflow.contollers.users.admin.AdminDashboardController">

   <!-- TOP MENU BAR -->
   <top>
      <VBox>
         <!-- Header -->
         <HBox spacing="20" style="-fx-background-color: #000060; -fx-padding: 15;">
            <VBox prefHeight="96.0">
               <children>
                  <Label prefHeight="40.0" text="Acadflow-Admin Potral" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  <HBox prefHeight="26.0" prefWidth="344.0">
                     <children>
                        <Label fx:id="adminNameLabel" style="-fx-font-size: 14px;" text="Welcome " textFill="#ecf0f1">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="username" text="Jhon Doe" textFill="WHITE">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Registration Number: " textFill="WHITE">
                           <font>
                              <Font size="14.0" />
                           </font>
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </Label>
                        <Label fx:id="userRegNo" prefHeight="20.0" text="admin1234" textFill="WHITE">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            <Region prefHeight="96.0" HBox.hgrow="ALWAYS" />
            <VBox prefHeight="88.0" prefWidth="100.0">
               <children>
                  <ImageView fx:id="userImg" fitHeight="76.0" fitWidth="98.0" pickOnBounds="true" preserveRatio="true" />
                  <Label alignment="CENTER" prefHeight="18.0" prefWidth="125.0" text="Administrator" textAlignment="CENTER" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox prefHeight="96.0" prefWidth="70.0">
               <children>
                  <Region prefHeight="33.0" prefWidth="100.0" visible="false" />
                  <Button fx:id="logoutBtn" onAction="#onLogoutBtnClick" prefHeight="34.0" prefWidth="68.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Logout">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </HBox>
      </VBox>
   </top>
   <center>
      <ScrollPane BorderPane.alignment="CENTER">
         <content>
      
                        <!-- Navigation Tabs -->
            <TabPane style="-fx-background-color: white;" tabClosingPolicy="UNAVAILABLE">
      
                           <!-- USERS TAB -->
               <Tab text="User Profiles">
                  <VBox spacing="10" style="-fx-padding: 20;">
                     <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="User Management" />

                     <!-- Search and Filter Controls -->
                     <HBox spacing="15">
                        <Label style="-fx-font-weight: bold;" text="User Type:" />
                        <ComboBox fx:id="userTypeCombo" prefWidth="150" promptText="Select User Type" />
                        <TextField fx:id="searchUserField" promptText="Search by name, email..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="searchUserButton" onAction="#searchUsers" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Search" />
                     </HBox>

                     <!-- Action Buttons -->
                     <HBox spacing="15">
                        <Button fx:id="addUserButton" onAction="#addUser" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Add New User" />
                        <Button fx:id="editUserButton" onAction="#editUser" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit User" />
                        <Button fx:id="deleteUserButton" onAction="#deleteUser" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete User" />
                        <Button fx:id="refreshUsersButton" onAction="#refreshUsers" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Refresh" />
                     </HBox>

                     <!-- Statistics Section -->
                     <HBox spacing="15" style="-fx-padding: 10 0 10 0;">
                        <Label style="-fx-font-weight: bold;" text="Statistics:" />
                        <Label fx:id="totalUsersLabel" style="-fx-text-fill: #2c3e50;" text="Total Users: 0" />
                        <Label fx:id="studentsCountLabel" style="-fx-text-fill: #2980b9;" text="Students: 0" />
                        <Label fx:id="teachersCountLabel" style="-fx-text-fill: #27ae60;" text="Teachers: 0" />
                        <Label fx:id="staffCountLabel" style="-fx-text-fill: #f39c12;" text="Staff: 0" />
                        <Label fx:id="adminsCountLabel" style="-fx-text-fill: #e74c3c;" text="Admins: 0" />
                     </HBox>

                     <!-- Users Table -->
                     <TableView fx:id="usersTable" prefHeight="400">
                        <placeholder>
                           <Label style="-fx-text-fill: #7f8c8d;" text="No users found. Click 'Add New User' to create one." />
                        </placeholder>
                     </TableView>

                     <!-- Status Bar -->
                     <HBox spacing="10" style="-fx-padding: 5 0 0 0;">
                        <Label fx:id="statusLabel" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Ready" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="recordCountLabel" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Showing 0 records" />
                     </HBox>
                  </VBox>
               </Tab>
      
                           <!-- COURSES TAB -->
               <Tab text="Courses">
                  <VBox spacing="10" style="-fx-padding: 20;">
                     <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Course Management" />
      
                                 <HBox spacing="15">
                        <TextField fx:id="courseCodeField" prefWidth="120" promptText="Course Code" />
                        <TextField fx:id="courseNameField" prefWidth="200" promptText="Course Name" />
                        <TextField fx:id="creditsField" prefWidth="80" promptText="Credits" />
                        <ComboBox fx:id="courseTypeField" prefHeight="26.0" prefWidth="119.0" promptText="Course Type" />
                        <ComboBox fx:id="courseDepartmentCombo" prefWidth="120" promptText="Department" />
                        <ComboBox fx:id="courseLecturerCombo" prefWidth="180" promptText="Select Lecturer" />
                        <Button fx:id="addCourseButton" onAction="#addCourse" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Add Course" />
                        <Button fx:id="updateCourseButton" onAction="#updateDialog" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Update" />
                        <Button fx:id="deleteCourseButton" onAction="#deleteCourse" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                     </HBox>
                     <Label fx:id="statusField" prefHeight="16.0" prefWidth="938.0" textFill="#f40000" />
                     <ScrollPane>
                        <content>
            
                                       <TableView fx:id="coursesTable" prefHeight="350" prefWidth="1130.0">
                              <columns>
                                 <TableColumn fx:id="courseCodeColomn" prefWidth="275.9999740719795" text="Course Code" />
                                 <TableColumn fx:id="CourseNameColomn" prefWidth="413.60003662109375" text="Course Name" />
                                 <TableColumn fx:id="CreditsColomn" prefWidth="97.60003662109375" text="Credits" />
                                 <TableColumn fx:id="CourseTypeColomn" prefWidth="171.20001220703125" text="Course Type" />
                                 <TableColumn fx:id="DepartmentColomn" prefWidth="174.39990234375" text="Department" />
                              </columns>
                           </TableView>
                        </content>
                     </ScrollPane>
                  </VBox>
               </Tab>
      
                           <!-- NOTICES TAB -->
               <Tab text="Notices">
                  <VBox spacing="10" style="-fx-padding: 20;">
                     <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Notice Board" />
      
                                 <HBox spacing="15">
                        <TextField fx:id="noticeTitleField" promptText="Notice Title" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="noticeAudienceCombo" prefWidth="150" promptText="Audience" />
                        <CheckBox fx:id="importantNoticeCheck" text="Important" />
                     </HBox>
      
                                 <TextArea fx:id="noticeContentArea" prefHeight="150" promptText="Enter notice content here..." />
      
                                 <HBox spacing="15">
                        <Button fx:id="publishNoticeButton" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Publish Notice" />
                        <Button fx:id="editNoticeButton" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit" />
                        <Button fx:id="deleteNoticeButton" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                     </HBox>
      
                                 <TableView fx:id="noticesTable" prefHeight="250" />
                  </VBox>
               </Tab>
      
                           <!-- TIMETABLES TAB -->
               <Tab text="Timetables">
                  <VBox spacing="10" style="-fx-padding: 20;">
                     <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Timetable Management" />
      
                                 <HBox spacing="15">
                        <ComboBox fx:id="timetableDepartmentCombo" prefWidth="150" promptText="Select Department" />
                        <ComboBox fx:id="timetableWeekCombo" prefWidth="150" promptText="Select Week" />
                        <ComboBox fx:id="timetableSemesterCombo" prefWidth="150" promptText="Select Semester" />
                        <Button fx:id="generateTimetableButton" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Generate" />
                        <Button fx:id="saveTimetableButton" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Save" />
                     </HBox>
      
                                 <TableView fx:id="timetableTable" prefHeight="350" />
                  </VBox>
               </Tab>
               <Tab text="My Profile">
                  <content>
                     <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                        <children>
                           <HBox prefHeight="562.0" prefWidth="1126.0" spacing="30" style="-fx-padding: 20;">
                              <children>
                                 <VBox spacing="15" style="-fx-alignment: center; -fx-pref-width: 250;">
                                    <children>
                                       <ImageView fx:id="userMainImage" fitHeight="150" fitWidth="150" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" />
                                       <Button fx:id="updateProPicBtn" onAction="#handleUploadButton" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Change Profile Picture" />
                                    </children>
                                 </VBox>
                                 <VBox prefHeight="522.0" prefWidth="771.0" spacing="15" style="-fx-pref-width: 400;">
                                    <children>
                                       <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Personal Information" />
                                       <GridPane hgap="15" vgap="10">
                                          <columnConstraints>
                                             <ColumnConstraints maxWidth="110.79996337890623" minWidth="93.19998779296873" prefWidth="97.99997558593748" />
                                             <ColumnConstraints maxWidth="291.6000122070312" minWidth="274.0000366210937" prefWidth="286.8000244140625" />
                                          </columnConstraints>
                                          <rowConstraints>
                                             <RowConstraints />
                                             <RowConstraints />
                                             <RowConstraints />
                                             <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                             <RowConstraints />
                                             <RowConstraints />
                                             <RowConstraints />
                                          </rowConstraints>
                                          <children>
                                             <Label prefHeight="18.0" prefWidth="270.0" style="-fx-font-weight: bold;" text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                             <Label style="-fx-font-weight: bold;" text="Admin ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                             <Label fx:id="regNoField" text="adminID" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                             <Label style="-fx-font-weight: bold;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                             <TextField fx:id="emailField" promptText="john.doe@students.ruhuna.ac.lk" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                             <Label style="-fx-font-weight: bold;" text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                             <TextArea fx:id="addressField" prefHeight="60" promptText="No. 123, Main Street, Galle" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                             <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
                                                <children>
                                                   <Button onAction="#saveProfileDetails" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="Update Profile" />
                                                   <Button fx:id="selfDetailsCancelBtn" onAction="#cancelSelfFormDetails" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Cancel" />
                                                </children>
                                             </HBox>
                                             <TextField fx:id="fullNameField" promptText="Jhone Doe" GridPane.columnIndex="1" />
                                             <Label layoutX="10.0" layoutY="78.0" style="-fx-font-weight: bold;" text="Gender:" GridPane.rowIndex="3" />
                                             <TextField fx:id="genderField" layoutX="113.0" layoutY="74.0" promptText="Male / Female" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                          </children>
                                       </GridPane>
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                        </children>
                     </AnchorPane>
                  </content>
               </Tab>
            </TabPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
