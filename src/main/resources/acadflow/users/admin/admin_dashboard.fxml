                  </Button>
                  <Button fx:id="timeTableBtn" alignment="CENTER" mnemonicParsing="false" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: #000060; -fx-cursor: hand;" text="  Manage Timetables" textFill="WHITE">
