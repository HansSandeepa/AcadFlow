<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

   <left>
      <VBox prefHeight="720.0" prefWidth="240.0" style="-fx-background-color: #E5E7EB;" BorderPane.alignment="CENTER">
