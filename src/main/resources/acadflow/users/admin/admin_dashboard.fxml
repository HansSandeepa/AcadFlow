               </children>
            </AnchorPane>

            <AnchorPane fx:id="contentArea" layoutX="20.0" layoutY="80.0" prefHeight="620.0" prefWidth="800.0" style="-fx-background-color: white; -fx-background-radius: 10;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="80.0">
