                        <Button fx:id="logoutBtn" mnemonicParsing="false" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: #e74c3c; -fx-cursor: hand;" text="Logout" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="15.0" /> </font>
                     <VBox.margin>
