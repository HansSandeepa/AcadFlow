<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"  style="-fx-background-color: #f4f6f9;">

   <top>
      <VBox>
         <!-- Header -->
         <HBox spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="LMS - Faculty of Technology" textFill="white">
               <font>
                  <Font name="Arial" size="20" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="adminNameLabel" style="-fx-font-size: 14px;" text="Admin" textFill="#ecf0f1" />
            <Label fx:id="adminRoleLabel" style="-fx-font-size: 12px;" text="Administrator" textFill="#bdc3c7" />
            <Button fx:id="logoutButton"  style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5;" text="Logout" />
         </HBox>

         <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: white;">

            <!-- ==================== USERS TAB ==================== -->
            <Tab text="User Profiles">
               <VBox spacing="10" style="-fx-padding: 20;">
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="User Management" />

                  <HBox spacing="15">
                     <Label text="User Type:" />
                     <ComboBox fx:id="userTypeCombo" promptText="Select User Type" prefWidth="150" />
                     <TextField fx:id="searchUserField" promptText="Search..." prefWidth="200" />
                     <Button fx:id="addUserButton"  style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Add New" />
                     <Button fx:id="editUserButton"  style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit" />
                     <Button fx:id="deleteUserButton"  style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                     <Button fx:id="refreshUsersButton" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Refresh" />
                  </HBox>

                  <TableView fx:id="usersTable" prefHeight="400" />
               </VBox>
            </Tab>

            <!-- ==================== COURSES TAB ==================== -->
            <Tab text="Courses">
               <VBox spacing="10" style="-fx-padding: 20;">
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Course Management" />

                  <HBox spacing="15">
                     <TextField fx:id="courseCodeField" promptText="Course Code" prefWidth="120" />
                     <TextField fx:id="courseNameField" promptText="Course Name" prefWidth="200" />
                     <TextField fx:id="creditsField" promptText="Credits" prefWidth="80" />
                     <ComboBox fx:id="courseDepartmentCombo" promptText="Department" prefWidth="120" />
                     <TextField fx:id="semesterField" promptText="Semester" prefWidth="80" />
                     <ComboBox fx:id="courseLecturerCombo" promptText="Select Lecturer" prefWidth="180" />
                     <Button fx:id="addCourseButton" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Add Course" />
                     <Button fx:id="updateCourseButton"  style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Update" />
                     <Button fx:id="deleteCourseButton" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                  </HBox>

                  <TableView fx:id="coursesTable" prefHeight="350" />
               </VBox>
            </Tab>

            <!-- ==================== NOTICES TAB ==================== -->
            <Tab text="Notices">
               <VBox spacing="10" style="-fx-padding: 20;">
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Notice Board" />

                  <HBox spacing="15">
                     <TextField fx:id="noticeTitleField" promptText="Notice Title" HBox.hgrow="ALWAYS" />
                     <ComboBox fx:id="noticeAudienceCombo" promptText="Audience" prefWidth="150" />
                     <CheckBox fx:id="importantNoticeCheck" text="Important" />
                  </HBox>

                  <TextArea fx:id="noticeContentArea" promptText="Enter notice content here..." prefHeight="150" />

                  <HBox spacing="15">
                     <Button fx:id="publishNoticeButton"  style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Publish Notice" />
                     <Button fx:id="editNoticeButton"  style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit" />
                     <Button fx:id="deleteNoticeButton"  style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                  </HBox>

                  <TableView fx:id="noticesTable" prefHeight="250" />
               </VBox>
            </Tab>

            <!-- ==================== TIMETABLES TAB ==================== -->
            <Tab text="Timetables">
               <VBox spacing="10" style="-fx-padding: 20;">
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Timetable Management" />

                  <HBox spacing="15">
                     <ComboBox fx:id="timetableDepartmentCombo" promptText="Select Department" prefWidth="150" />
                     <ComboBox fx:id="timetableWeekCombo" promptText="Select Week" prefWidth="150" />
                     <ComboBox fx:id="timetableSemesterCombo" promptText="Select Semester" prefWidth="150" />
                     <Button fx:id="generateTimetableButton"  style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Generate" />
                     <Button fx:id="saveTimetableButton"  style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Save" />
                  </HBox>

                  <TableView fx:id="timetableTable" prefHeight="350" />
               </VBox>
            </Tab>
         </TabPane>
      </VBox>
   </top>
</BorderPane>