                     </VBox.margin>
                  </Button>
                  <Button fx:id="noticesBtn" alignment="CENTER" mnemonicParsing="false" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: #000060; -fx-cursor: hand;" text="  Manage Notices" textFill="WHITE">
                     <font><Font name="System Bold" size="15.0" /></font>
